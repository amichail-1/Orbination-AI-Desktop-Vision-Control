{
  "$schema": "https://registry.modelcontextprotocol.io/schemas/server.json",
  "name": "io.github.amichail-1/desktop-vision-control",
  "description": "Native Windows MCP server that gives AI assistants full desktop automation — see the screen, read UI elements, click buttons, type text, and control any application via Win32 + UIAutomation.",
  "version": "1.0.0",
  "repository": {
    "url": "https://github.com/amichail-1/Orbination-AI-Desktop-Vision-Control",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "github-releases",
      "identifier": "amichail-1/Orbination-AI-Desktop-Vision-Control",
      "version": "1.0.0",
      "runtimeHint": {
        "platform": "windows"
      }
    }
  ],
  "tools": [
    "scan_desktop", "list_windows", "focus_window", "get_window_details",
    "find_element", "click_element", "type_in_element", "interact",
    "fill_form", "select_tab", "refresh_window", "read_window_text",
    "mouse_click", "mouse_move", "mouse_drag", "mouse_scroll",
    "keyboard_type", "keyboard_press", "keyboard_hotkey",
    "keyboard_key_down", "keyboard_key_up",
    "screenshot_to_file", "screenshot_region", "get_screen_info",
    "click_and_type", "navigate_to_url", "auto_scroll",
    "maximize_window", "minimize_window", "restore_window",
    "open_app", "wait_seconds"
  ],
  "remoteEndpoints": [],
  "environmentVariables": []
}
